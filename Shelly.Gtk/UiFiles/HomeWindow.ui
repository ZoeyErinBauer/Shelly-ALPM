<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name HomeWindow.ui -->
  <requires lib="gtk" version="4.0"/>
  <object class="GtkOverlay" id="HomeWindowOverlay">
    <property name="child">
      <object class="GtkBox" id="HomeWindow">
        <property name="margin-bottom">10</property>
        <property name="margin-end">10</property>
        <property name="margin-start">10</property>
        <property name="margin-top">10</property>
        <property name="orientation">vertical</property>
        <property name="spacing">10</property>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">5</property>
            <property name="vexpand">true</property>
            <child>
              <object class="GtkLabel">
                <property name="label">Shelly Search</property>
                <property name="xalign">0</property>
                <style>
                  <class name="title-2"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkSearchEntry" id="HomeSearchEntry">
                <property name="placeholder-text">Search all sources...</property>
                <property name="hexpand">true</property>
              </object>
            </child>
            <child>
              <object class="GtkOverlay" id="MetaSearchOverlay">
                <property name="vexpand">true</property>
                <property name="child">
                  <object class="GtkFrame">
                    <property name="vexpand">true</property>
                    <style>
                      <class name="rounded-card"/>
                    </style>
                    <child>
                      <object class="GtkBox" id="MetaSearchContainer">
                        <property name="orientation">vertical</property>
                        <property name="spacing">5</property>
                        <property name="vexpand">true</property>
                      </object>
                    </child>
                  </object>
                </property>
                <child type="overlay">
                  <object class="GtkBox" id="SearchPromptOverlay">
                    <property name="visible">true</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <property name="valign">center</property>
                    <property name="halign">center</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Search above to query all avaliable sources (Packages, AUR, or Flatpak) that you have enabled</property>
                        <property name="wrap">true</property>
                        <property name="justify">center</property>
                        <style>
                          <class name="dim-label"/>
                          <class name="title-4"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">10</property>
            <property name="hexpand">true</property>
            <property name="homogeneous">true</property>
            <child>
              <object class="GtkFrame">
                <property name="hexpand">true</property>
                <property name="width-request">300</property>
                <property name="height-request">210</property>
                <style>
                  <class name="rounded-card"/>
                </style>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">5</property>
                    <property name="margin-bottom">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-start">10</property>
                    <property name="margin-top">10</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Recent Activity</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="title-2"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScrolledWindow">
                        <property name="vscrollbar-policy">automatic</property>
                        <property name="hscrollbar-policy">never</property>
                        <property name="height-request">150</property>
                        <child>
                          <object class="GtkListBox" id="OperationLogListBox">
                            <property name="selection-mode">none</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkScrolledWindow">
                <property name="overlay-scrolling">false</property>
                <property name="has-frame">true</property>
                <property name="hscrollbar-policy">never</property>
                <property name="vscrollbar-policy">never</property>
                <property name="hexpand">true</property>
                <property name="width-request">300</property>
                <property name="height-request">210</property>
                <style>
                  <class name="rounded-card"/>
                </style>
                <child>
                  <object class="GtkBox">
                    <property name="halign">center</property>
                    <property name="margin-bottom">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-start">10</property>
                    <property name="margin-top">10</property>
                    <property name="orientation">vertical</property>
                    <property name="spacing">10</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Package Dashboard</property>
                        <property name="xalign">0</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="title-2"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="homogeneous">true</property>
                        <property name="orientation">horizontal</property>
                        <property name="spacing">20</property>
                        <child>
                          <object class="GtkBox" id="AurBox">
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Total Aur</property>
                                <style>
                                  <class name="caption"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="TotalAurLabel">
                                <property name="label">0</property>
                                <style>
                                  <class name="title-1"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="AurStatusLabel">
                                <property name="label">Up to date</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="AurPercentLabel">
                                <property name="justify">center</property>
                                <property name="label">Calculating</property>
                                <accessibility>
                                  <property name="orientation">horizontal</property>
                                  <property name="sort">other</property>
                                </accessibility>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Total Packages</property>
                                <style>
                                  <class name="caption"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="TotalPackagesLabel">
                                <property name="label">0</property>
                                <style>
                                  <class name="title-1"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="PackagesStatusLabel">
                                <property name="label">Up to date</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="StandardPercent">
                                <property name="justify">center</property>
                                <property name="label">Calculating</property>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkBox" id="FlatpakBox">
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel">
                                <property name="label">Total Flatpak</property>
                                <style>
                                  <class name="caption"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="TotalFlatpakLabel">
                                <property name="label">0</property>
                                <style>
                                  <class name="title-1"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="FlatpakStatusLabel">
                                <property name="label">Up to date</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="FlatpakPercent">
                                <property name="justify">center</property>
                                <property name="label">Calculating</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="halign">center</property>
                        <property name="spacing">10</property>
                        <property name="margin-top">10</property>
                        <child>
                          <object class="GtkButton" id="ExportSyncButton">
                            <property name="label">Export Sync file</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="UpgradeAllButton">
                            <property name="label">Upgrade All</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkFrame">
                <property name="height-request">210</property>
                <property name="width-request">300</property>
                <property name="hexpand">true</property>
                <style>
                  <class name="rounded-card"/>
                </style>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">5</property>
                    <property name="width-request">200</property>
                    <property name="margin-bottom">10</property>
                    <property name="margin-end">10</property>
                    <property name="margin-start">10</property>
                    <property name="margin-top">10</property>
                    <child>
                      <object class="GtkLabel">
                        <property name="label">Arch News</property>
                        <property name="xalign">0</property>
                        <style>
                          <class name="title-2"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox" id="ArchNewsContentBox">
                        <property name="orientation">vertical</property>
                        <property name="vexpand">false</property>
                        <property name="valign">center</property>
                        <property name="spacing">8</property>
                        <property name="width-request">200</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">horizontal</property>
                        <property name="halign">center</property>
                        <property name="spacing">8</property>
                        <property name="margin-top">8</property>
                        <child>
                          <object class="GtkButton" id="ArchNewsPrevButton">
                            <property name="icon-name">go-previous-symbolic</property>
                            <property name="sensitive">false</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="ArchNewsPageLabel">
                            <property name="label">0 / 0</property>
                            <style>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton" id="ArchNewsNextButton">
                            <property name="icon-name">go-next-symbolic</property>
                            <property name="sensitive">false</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
    <child type="overlay">
      <object class="GtkRevealer" id="UpdatesRevealer">
        <property name="transition-type">slide-left</property>
        <property name="transition-duration">300</property>
        <property name="halign">end</property>
        <property name="valign">fill</property>
        <property name="margin-end">24</property>
        <property name="reveal-child">false</property>
        <child>
          <object class="GtkFrame">
            <style>
              <class name="rounded-card"/>
            </style>
            <child>
              <object class="GtkBox" id="UpdatesPanelBox">
                <property name="orientation">vertical</property>
                <property name="spacing">5</property>
                <property name="width-request">350</property>
                <property name="margin-bottom">10</property>
                <property name="margin-end">10</property>
                <property name="margin-start">10</property>
                <property name="margin-top">10</property>
                <child>
                  <object class="GtkLabel">
                    <property name="label">Available Updates</property>
                    <style>
                      <class name="title-3"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkScrolledWindow">
                    <property name="vexpand">true</property>
                    <child>
                      <object class="GtkListBox" id="UpdatesListBox">
                        <property name="selection-mode">none</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
    <child type="overlay">
      <object class="GtkToggleButton" id="ShowUpdatesButton">
        <property name="halign">end</property>
        <property name="valign">center</property>
        <property name="width-request">24</property>
        <property name="vexpand">true</property>
        <property name="has-frame">false</property>
        <property name="opacity">0.5</property>
        <property name="tooltip-text">Toggle Available Updates</property>
        <child>
          <object class="GtkImage" id="ShowUpdatesArrow">
            <property name="icon-name">pan-start-symbolic</property>
            <property name="pixel-size">24</property>
          </object>
        </child>
        <style>
          <class name="osd"/>
        </style>
      </object>
    </child>
  </object>
</interface>
